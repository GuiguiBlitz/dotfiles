# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
  . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
  PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
  for rc in ~/.bashrc.d/*; do
    [ -f "$rc" ] && . "$rc"
  done
  unset rc
fi

export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ]             && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ]    && . "$NVM_DIR/bash_completion"
[ -f "$HOME/.cargo/env" ]            && . "$HOME/.cargo/env"
[ -f "$HOME/.local/bin/env" ]        && . "$HOME/.local/bin/env"

rustormy -c Lyon --colors

# brew
for _d in /home/linuxbrew/.linuxbrew /opt/homebrew /usr/local; do
  [ -x "$_d/bin/brew" ] && eval "$("$_d/bin/brew" shellenv bash)" && break
done
unset _d

# bash-preexec — delay install so it doesn't conflict with anything in profile.d
__bp_delay_install=1
[ -f "${HOMEBREW_PREFIX}/etc/profile.d/bash-preexec.sh" ] && source "${HOMEBREW_PREFIX}/etc/profile.d/bash-preexec.sh"

# init tools (starship already done by /etc/profile.d on bluefin; runs here on other systems)
command -v starship >/dev/null && ! declare -f starship_precmd >/dev/null 2>&1 && eval "$(starship init bash)"
command -v direnv   >/dev/null && eval "$(direnv hook bash)"
command -v zoxide   >/dev/null && eval "$(zoxide init bash)"
command -v mise     >/dev/null && eval "$(mise activate bash)"
command -v atuin    >/dev/null && eval "$(atuin init bash)"

# install bash-preexec hooks now that all tools are registered
unset __bp_delay_install
declare -f __bp_install >/dev/null 2>&1 && __bp_install

# aliases
alias ls="eza --icons"
alias ll="eza -l --icons --group-directories-first"
alias la="eza -a --icons --group-directories-first"
alias lla="eza -la --icons --group-directories-first"
alias cat="bat -pp"
